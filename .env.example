# Knowledge Synthesis Engine - Configuration

# Server Port
PORT=3000

# Database Path (Local JSON)
DB_PATH=./data/knowledge_graph.json

# Admin API Key (X-API-KEY)
ADMIN_API_KEY=your_admin_key_here

# --- LLM PROVIDERS ---

# Google Gemini (Primary Ingestion & Translation)
GEMINI_API_KEY=your_gemini_key_here

# xAI Grok (Logical Audit & Hallucination Detection)
GROK_API_KEY=your_grok_key_here

# OpenRouter (Synthesis & Discovery)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenCode Zen (Structural Architecture)
OPENCODE_ZEN_KEY=your_opencode_key_here

# OpenAI (Optional Fallback)
OPENAI_API_KEY=your_openai_key_here

# --- RESEARCH CONFIG ---
DEFAULT_RESEARCH_DOMAIN=solid state battery
